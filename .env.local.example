# ===========================================================
# RAASA HARVEST — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ===========================================================

# -----------------------------------------------------------
# FIREBASE CLIENT (safe to expose — prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=xx
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xx
NEXT_PUBLIC_FIREBASE_APP_ID=xx

# -----------------------------------------------------------
# FIREBASE ADMIN SDK (SERVER-SIDE ONLY — never NEXT_PUBLIC_)
# Generate from: Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single-line string, escaped.
# -----------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------
# SESSION / AUTH
# -----------------------------------------------------------
# Secret for signing session cookies — generate with: openssl rand -base64 32
SESSION_SECRET=your_very_long_random_secret_here

# -----------------------------------------------------------
# WHATSAPP
# -----------------------------------------------------------
# Replace with your actual WhatsApp Business number (no + or spaces)
NEXT_PUBLIC_WA_NUMBER=919000000000
